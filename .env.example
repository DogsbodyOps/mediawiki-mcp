# Copy this file to .env and fill in your values.
# Never commit .env to version control.

WIKI_URL=
WIKI_USERNAME=
WIKI_PASSWORD=
WIKI_TOTP_SECRET=

# Set to true to enable wiki_edit_page, wiki_section_edit, wiki_append_to_page (Default to False for safety)
WIKI_ALLOW_WRITE=false

# HTTP server (hosted/Docker mode)
MCP_API_KEY=total-garbage-api-key
PORT=8000
